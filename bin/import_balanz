#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/argpt"

path = ARGV[0]
unless path && File.exist?(path)
  warn "Usage: ruby bin/import_balanz <path-to-resultados.xlsx>"
  exit 1
end

holdings = Argpt::Import::Balanz.new(path:).call

spinoffs = holdings.select { |h| h.avg_price <= 0.01 && h.purchase_date }
if spinoffs.any?
  puts "Resolving prices for #{spinoffs.length} spinoff lot(s): #{spinoffs.map(&:ticker).join(', ')}"
  data912 = Argpt::DataSources::Data912.new(client: Argpt::HttpClient.new)
  holdings = Argpt::Import::SpinoffPricer.new(holdings:, data912:).call
end

# Merge with existing holdings (keep non-Balanz holdings)
data_dir = File.join(__dir__, "..", "frontend", "data")
holdings_path = File.join(data_dir, "holdings.json")

existing = if File.exist?(holdings_path)
  JSON.parse(File.read(holdings_path), symbolize_names: true)
    .reject { |h| h[:broker] == "balanz" }
else
  []
end

holdings_json = holdings.map do |h|
  {
    ticker: h.ticker,
    type: h.type.to_s,
    shares: h.shares,
    avg_price: h.avg_price.round(2),
    purchase_date: h.purchase_date&.to_s,
    entry_fx_rate: h.purchase_fx_rate&.round(2),
    broker: h.broker.to_s
  }
end

merged = existing + holdings_json
FileUtils.mkdir_p(data_dir)
File.write(holdings_path, JSON.pretty_generate(merged))

# Merge config/holdings.yml
config_path = File.join(__dir__, "..", "config", "holdings.yml")
existing_config = if File.exist?(config_path)
  YAML.safe_load(File.read(config_path)) || {}
else
  {}
end

existing_tickers = (existing_config["tickers"] || []).reject { |t| t["broker"] == "balanz" }
new_tickers = holdings.uniq { |h| [h.ticker, h.type] }.map { |h| { "ticker" => h.ticker, "type" => h.type.to_s, "broker" => "balanz" } }
config = { "tickers" => existing_tickers + new_tickers }
FileUtils.mkdir_p(File.dirname(config_path))
File.write(config_path, YAML.dump(config))

# Print summary
cedears = holdings.select { |h| h.type == :cedear }
arg_stocks = holdings.select { |h| h.type == :arg_stock }

puts "Imported #{holdings.length} holdings from Balanz export"
puts "  Argentine stocks: #{arg_stocks.length}"
puts "  CEDEARs: #{cedears.length}"
puts
puts format("%-8s %-12s %8s %12s %10s", "Ticker", "Type", "Shares", "Avg Price", "Entry MEP")
puts "-" * 55
holdings.sort_by { |h| [h.type.to_s, h.ticker] }.each do |h|
  puts format("%-8s %-12s %8.0f %12.2f %10s",
    h.ticker, h.type, h.shares, h.avg_price,
    h.purchase_fx_rate ? format("%.2f", h.purchase_fx_rate) : "n/a")
end
puts
puts "Written: #{config_path}"
puts "Written: #{File.join(data_dir, 'holdings.json')}"
