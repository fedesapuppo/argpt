#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/argpt"

path = ARGV[0]
unless path && File.exist?(path)
  warn "Usage: ruby bin/import_ib <path-to-ib-activity-statement.csv>"
  exit 1
end

holdings = Argpt::Import::InteractiveBrokers.new(path:).call

# Merge with existing holdings (keep non-IB holdings)
data_dir = File.join(__dir__, "..", "frontend", "data")
holdings_path = File.join(data_dir, "holdings.json")

existing = if File.exist?(holdings_path)
  JSON.parse(File.read(holdings_path), symbolize_names: true)
    .reject { |h| h[:broker] == "ib" }
else
  []
end

new_holdings_json = holdings.map do |h|
  {
    ticker: h.ticker,
    type: h.type.to_s,
    shares: h.shares,
    avg_price: h.avg_price.round(2),
    purchase_date: h.purchase_date&.to_s,
    entry_fx_rate: h.purchase_fx_rate&.round(2),
    broker: h.broker.to_s
  }
end

merged = existing + new_holdings_json
FileUtils.mkdir_p(data_dir)
File.write(holdings_path, JSON.pretty_generate(merged))

# Merge config/holdings.yml
config_path = File.join(__dir__, "..", "config", "holdings.yml")
existing_config = if File.exist?(config_path)
  YAML.safe_load(File.read(config_path)) || {}
else
  {}
end

existing_tickers = (existing_config["tickers"] || []).reject { |t| t["broker"] == "ib" }
new_tickers = holdings.uniq(&:ticker).map { |h| { "ticker" => h.ticker, "type" => h.type.to_s, "broker" => "ib" } }
config = { "tickers" => existing_tickers + new_tickers }
FileUtils.mkdir_p(File.dirname(config_path))
File.write(config_path, YAML.dump(config))

# Print summary
puts "Imported #{holdings.length} holdings from Interactive Brokers"
puts
puts format("%-8s %12s %12s", "Ticker", "Shares", "Avg Price")
puts "-" * 35
holdings.sort_by(&:ticker).each do |h|
  puts format("%-8s %12s %12.2f",
    h.ticker, h.shares % 1 == 0 ? h.shares.to_i.to_s : format("%.4f", h.shares), h.avg_price)
end
puts
puts "Written: #{config_path}"
puts "Written: #{holdings_path}"
