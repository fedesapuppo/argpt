{
  "name": "argpt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Argentine Portfolio Tracker — frontend dev tooling (tests + Tailwind build). Production deploy is still static files from frontend/.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build:css": "tailwindcss -i frontend/src/tailwind.css -o frontend/css/tailwind.css --minify",
    "dev:css": "tailwindcss -i frontend/src/tailwind.css -o frontend/css/tailwind.css --watch"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "tailwindcss": "^3.4.0"
  }
}
